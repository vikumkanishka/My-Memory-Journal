# ============================================
# Environment Variables for Backend Server
# Copy this file to .env and fill in your values
# ============================================

# JWT Secret Key - Change this to a secure random string!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# Server Port
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500

# Node Environment
NODE_ENV=development

# Database Path (if using file-based storage)
DATABASE_PATH=./database/users.json

# Optional: Email Configuration (for password reset, verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Rate Limiting
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT=24h
